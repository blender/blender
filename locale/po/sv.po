msgid ""
"Reflection for materials such as cloth.\n"
"Typically mixed with other shaders (such as a Diffuse Shader) and is not particularly useful on its own"
msgstr "Reflektion för material som tyg. Blandas vanligtvis med andra shader (som en diffus shader) och är inte särskilt användbar på egen hand."


msgid "Sheen shading model"
msgstr "Sheen-skuggmodell"


msgid "Ashikhmin"
msgstr "Ashikhmin"


msgid "Classic Ashikhmin velvet (legacy model)"
msgstr "Klassisk Ashikhmin-sammet (äldre modell)"


msgid "Microfiber"
msgstr "Mikrofiber"


msgid "Microflake-based model of multiple scattering between normal-oriented fibers"
msgstr "Mikroflakbaserad modell för multipel spridning mellan normalt orienterade fibrer"


msgid "Toon BSDF"
msgstr "Toon BSDF"


msgid "Diffuse and Glossy shaders with cartoon light effects"
msgstr "Diffusa och glansiga shader med tecknade ljuseffekter"


