msgstr "Koppla bort denna åtgärd från den aktiva åtgärdsplatsen (och/eller avsluta Tweak Mode)"


msgid "Force Delete"
msgstr "Tvinga borttagning"


msgid "Clear Fake User and remove copy stashed in this data-block's NLA stack"
msgstr "Rensa bort falska användare och ta bort kopior som lagrats i detta datablocks NLA-stack."


msgctxt "Operator"
msgid "Frame All"
msgstr "Bildruta All"


msgid "Reset viewable area to show full keyframe range"
msgstr "Återställ synligt område för att visa hela nyckelbildintervallet"


msgctxt "Operator"
msgid "Go to Current Frame"
msgstr "Gå till aktuell bildruta"


msgid "Move the view to the current frame"
msgstr "Flytta vyn till den aktuella bildrutan"


msgctxt "Operator"
msgid "Frame Selected"
msgstr "Bildruta vald"


