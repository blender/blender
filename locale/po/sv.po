msgstr "Lägg till tom sökväg till aktiv nyckelsats"


msgctxt "Operator"
msgid "Remove Active Keying Set Path"
msgstr "Ta bort aktiv nyckeluppsättning"


msgid "Remove active Path from active keying set"
msgstr "Ta bort aktiv sökväg från aktiv nyckeluppsättning"


msgctxt "Operator"
msgid "Remove Active Keying Set"
msgstr "Ta bort aktivt nyckelset"


msgid "Remove the active keying set"
msgstr "Ta bort den aktiva nyckelsatsen"


msgctxt "Operator"
msgid "Add to Keying Set"
msgstr "Lägg till i nyckelsats"


msgid "Add current UI-active property to current keying set"
msgstr "Lägg till aktuell UI-aktiv egenskap till aktuell nyckelsats"


msgid "Add all elements of the array to a Keying Set"
msgstr "Lägg till alla element i matrisen till en nyckeluppsättning"


msgctxt "Operator"
msgid "Remove from Keying Set"
msgstr "Ta bort från tangentuppsättning"


msgid "Remove current UI-active property from current keying set"
msgstr "Ta bort aktuell UI-aktiv egenskap från aktuell nyckelsats"


msgctxt "Operator"
msgid "Merge Animation"
msgstr "Sammanfoga animation"


msgid "Merge the animation of the selected objects into the action of the active object. Actions are not deleted by this, but might end up with zero users"
msgstr "Slå ihop animeringen av de valda objekten med det aktiva objektets åtgärd. Åtgärder raderas inte av detta, men kan sluta med noll användare."


msgctxt "Operator"
msgid "Paste Driver"
msgstr "Klistra in drivrutin"


msgid "Paste the driver in the internal clipboard to the highlighted button"
msgstr "Klistra in drivrutinen i det interna urklippet till den markerade knappen"


msgctxt "Operator"
msgid "Clear Preview Range"
msgstr "Rensa förhandsgranskningsintervall"


msgid "Clear preview range"
msgstr "Tydligt förhandsgranskningsområde"


msgctxt "Operator"
msgid "Set Preview Range"
msgstr "Ställ in förhandsgranskningsintervall"


msgid "Interactively define frame range used for playback"
msgstr "Interaktivt definiera bildruteintervall som används för uppspelning"


msgctxt "Operator"
msgid "Replace Action"
msgstr "Ersätt åtgärd"


msgid "Swap all users of one action to another one. The normal action slot assignment rules apply. This ignores the NLA and Action Constraints"
msgstr "Byt alla användare av en åtgärd till en annan. De normala reglerna för tilldelning av åtgärdsslots gäller. Detta ignorerar NLA och åtgärdsbegränsningar."


msgid "Replacement Action"
msgstr "Ersättningsåtgärd"


msgid "The replacement Action's session uid to remap all selected Action's users to"
msgstr "Ersättningsåtgärdens sessions-uid för att ommappa alla valda åtgärdsanvändare till"


msgid "Old Action"
msgstr "Gammal åtgärd"


msgid "Old Action's session uid to replace"
msgstr "Old Action-sessionens uid att ersätta"


msgctxt "Operator"
msgid "Replace with new Action"
msgstr "Ersätt med ny åtgärd"


msgid "Swap all users of one action to a new action. This ignores the NLA and Action Constraints"
msgstr "Byt alla användare av en åtgärd till en ny åtgärd. Detta ignorerar NLA och åtgärdsbegränsningar."


msgctxt "Operator"
msgid "Frame Scene/Preview Range"
msgstr "Ramscen/Förhandsgranskningsområde"


msgid "Reset the horizontal view to the current scene frame range, taking the preview range into account if it is active"
msgstr "Återställ den horisontella vyn till det aktuella scenramområdet, med hänsyn till förhandsgranskningsområdet om det är aktivt."


msgctxt "Operator"
msgid "Separate Slots"
msgstr "Separata platser"


msgid "Move all slots of the action on the active object into newly created, separate actions. All users of those slots will be reassigned to the new actions. The current action won't be deleted but will be empty and might end up having zero users"
msgstr "Flytta alla platser för åtgärden på det aktiva objektet till nyskapade, separata åtgärder. Alla användare av dessa platser kommer att omfördelas till de nya åtgärderna. Den aktuella åtgärden kommer inte att raderas, men kommer att vara tom och kan i slutändan ha noll användare."


msgctxt "Operator"
msgid "Move Slots to new Action"
msgstr "Flytta slots till ny åtgärd"


msgid "Move the selected slots into a newly created action"
msgstr "Flytta de valda platserna till en nyåtgärd"


msgid "Create a new action slot for this data-block, to hold its animation"
msgstr "Skapa en ny åtgärdsplats för detta datablock, för att lagra dess animering."


msgid "Un-assign the action slot from this constraint"
msgstr "Avaktivera åtgärdsslottet från denna begränsning"


msgid "Un-assign the action slot, effectively making this data-block non-animated"
msgstr "Avaktivera åtgärdsslottet, vilket gör att detta datablock inte animeras."


msgid "Un-assign the action slot from this NLA strip, effectively making it non-animated"
msgstr "Avaktivera åtgärdsslottet från denna NLA-remsa, vilket gör den icke-animerad."


msgctxt "Operator"
msgid "Set Start Frame"
msgstr "Ställ in startbildruta"


