msgstr "Ta bort taggen \"disabled\" från alla F-kurvor för att få trasiga F-kurvor att fungera igen."


msgctxt "Operator"
msgid "Group Channels"
msgstr "Gruppkanaler"


msgid "Add selected F-Curves to a new group"
msgstr "Lägg till valda F-kurvor till en ny grupp"


msgid "Name of newly created group"
msgstr "Namn på nybildad grupp"


msgctxt "Operator"
msgid "Move Channels"
msgstr "Flytta kanaler"


