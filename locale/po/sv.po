msgstr "Aktivera"


msgctxt "Operator"
msgid "Expand Channels"
msgstr "Expandera kanaler"


msgid "Expand (open) all selected expandable animation channels"
msgstr "Expandera (öppna) alla valda expanderbara animationskanaler"


msgid "Expand all channels (not just selected ones)"
msgstr "Expandera alla kanaler (inte bara valda kanaler)"


msgctxt "Operator"
msgid "Revive Disabled F-Curves"
msgstr "Återuppliva inaktiverade F-kurvor"


