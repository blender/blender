msgstr "Infoga nyckelrutor i den aktuella rutan med hjälp av antingen den aktiva nyckelsatsen eller användarinställningarna om ingen nyckelsats är aktiv."


msgctxt "Operator"
msgid "Insert Keyframe (Buttons)"
msgstr "Infoga nyckelbildruta (knappar)"


msgid "Insert a keyframe for current UI-active property"
msgstr "Infoga en nyckelbildruta för aktuell UI-aktiv egenskap"


msgid "Insert a keyframe for all element of the array"
msgstr "Infoga en nyckelbildruta för alla element i matrisen"


msgctxt "Operator"
msgid "Insert Keyframe (by name)"
msgstr "Infoga nyckelbildruta (efter namn)"


msgid "Alternate access to 'Insert Keyframe' for keymaps to use"
msgstr "Alternativ åtkomst till \"Infoga nyckelruta\" för nyckelkartor att använda"


msgctxt "Operator"
msgid "Insert Keyframe Menu"
msgstr "Infoga nyckelbildmeny"


msgid "Insert Keyframes for specified Keying Set, with menu of available Keying Sets if undefined"
msgstr "Infoga nyckelrutor för angiven nyckelsats, med meny över tillgängliga nyckelsatser om ingen är definierad."


msgid "Always Show Menu"
msgstr "Visa alltid meny"


msgctxt "Operator"
msgid "Set Active Keying Set"
msgstr "Ställ in aktiv nyckeluppsättning"


msgid "Set a new active keying set"
msgstr "Ställ in en ny aktiv nyckelsats"


msgctxt "Operator"
msgid "Add Empty Keying Set"
msgstr "Lägg till tomt tangentset"


msgid "Add a new (empty) keying set to the active Scene"
msgstr "Lägg till en ny (tom) nyckelsats till den aktiva scenen"


msgid "Filter folders"
msgstr "Filtrera mappar"


msgid "Filter Python"
msgstr "Filter Python"


msgid "Filter text"
msgstr "Filtrera text"


msgctxt "Operator"
msgid "Add Empty Keying Set Path"
msgstr "Lägg till tomt tangentsättningsspår"


