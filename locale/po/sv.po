msgid "Subsurface Method"
msgstr "Metod under ytan"


msgid "Method for rendering subsurface scattering"
msgstr "Metod för att återge spridning under ytan"


msgid "Christensen-Burley"
msgstr "Christensen-Burley"


msgid "Approximation to physically based volume scattering"
msgstr "Approximation till fysikaliskt baserad volymspridning"


msgid "Random Walk"
msgstr "Slumpmässig promenad"


msgid "Volumetric approximation to physically based volume scattering, using the scattering radius as specified"
msgstr "Volymetrisk approximation till fysikaliskt baserad volymspridning, med användning av den angivna spridningsradien"


msgid "Random Walk (Skin)"
msgstr "Slumpmässig promenad (Skin)"


