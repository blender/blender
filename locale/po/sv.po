msgstr "Tillåt en annan operatör att arbeta med remhandtag"


msgid "Strip Preview"
msgstr "Förhandsgranska serier"


msgctxt "Operator"
msgid "Select Channel Keyframes"
msgstr "Välj kanalens nyckelrutor"


