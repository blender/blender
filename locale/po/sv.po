msgstr "Återlämning"


msgid "True when this property is an output value from an RNA function"
msgstr "Sant när denna egenskap är ett utdatavärde från en RNA-funktion."


msgid "Overridable"
msgstr "Överstyrbar"


msgid "Property is overridable through RNA"
msgstr "Egendom kan åsidosättas genom RNA"


msgid "Path Output"
msgstr "Sökväg Utgång"


msgid "Property is a filename, filepath or directory output"
msgstr "Egenskapen är ett filnamn, en filväg eller en katalogutdata."


msgid "Path Relative"
msgstr "Relativ sökväg"


msgid "Property is a path which supports the \"//\" prefix, signifying the location as relative to the \".blend\" file's directory"
msgstr "Egenskapen är en sökväg som stöder prefixet \"//\", vilket anger platsen relativt till \".blend\"-filens katalog."


msgid "Variable Expression Support"
msgstr "Stöd för variabla uttryck"


msgid "Property is a path which supports the \"{variable_name}\" variable expression syntax, which substitutes the value of the referenced variable in place of the expression"
msgstr "Egenskapen är en sökväg som stöder syntaxen för variabeluttrycket \"{variable_name}\", som ersätter värdet för den refererade variabeln i stället för uttrycket."


msgid "Read Only"
msgstr "Skrivskyddad"


msgid "Property is editable through RNA"
msgstr "Fastigheten kan redigeras via RNA."


msgid "Registered"
msgstr "Registrerad"


msgid "Property is registered as part of type registration"
msgstr "Fastigheten registreras som en del av typregistreringen."


msgid "Registered Optionally"
msgstr "Registrerad valfritt"


msgid "Property is optionally registered as part of type registration"
msgstr "Fastigheten registreras valfritt som en del av typregistreringen."


msgid "Required"
msgstr "Obligatoriskt"


msgid "False when this property is an optional argument in an RNA function"
msgstr "Falsk när denna egenskap är ett valfritt argument i en RNA-funktion."


msgid "Runtime"
msgstr "Körtid"


msgid "Property has been dynamically created at runtime"
msgstr "Egenskapen har skapats dynamiskt vid körningstillfället."


msgid "Skip Preset"
msgstr "Hoppa över förinställning"


msgid "True when the property is not saved in presets"
msgstr "Sant när egenskapen inte sparas i förinställningar"


msgid "Skip Save"
msgstr "Hoppa över Spara"


msgid "True when the property uses ghost values"
msgstr "Sant när egenskapen använder spökvärden"


