msgstr "Välj alla animationskanaler inom det angivna området"


msgid "Deselect rather than select items"
msgstr "Avmarkera snarare än markera objekt"


msgid "Extend selection instead of deselecting everything first"
msgstr "Utöka markeringen istället för att först avmarkera allt"


msgctxt "Operator"
msgid "Filter Channels"
msgstr "Filterkanaler"


msgid "Start entering text which filters the set of channels shown to only include those with matching names"
msgstr "Börja skriva in text som filtrerar de visade kanalerna så att endast de med matchande namn visas."


msgctxt "Operator"
