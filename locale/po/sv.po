msgstr "Återställ synligt område för att visa kanalen under markören"


msgid "Include Handles"
msgstr "Inkludera handtag"


msgid "Include handles of keyframes when calculating extents"
msgstr "Inkludera nyckelrutors handtag vid beräkning av omfattning"


msgid "Ignore frames outside of the preview range"
msgstr "Ignorera bildrutor utanför förhandsgranskningsområdet"


msgctxt "Operator"
msgid "Bake Channels"
msgstr "Baka kanaler"


msgid "Create keyframes following the current shape of F-Curves of selected channels"
msgstr "Skapa nyckelrutor som följer den aktuella formen på F-kurvorna för valda kanaler."


msgid "Bake Modifiers"
msgstr "Bakningsmodifierare"


msgid "Bake Modifiers into keyframes and delete them after"
msgstr "Baka modifierare i nyckelrutor och ta bort dem efteråt"


msgid "Choose the interpolation type with which new keys will be added"
msgstr "Välj interpoleringstyp som nya nycklar ska läggas till med"


msgid "New keys will be Bézier"
msgstr "Nya tangenter kommer att vara Bézier"


msgid "New keys will be linear"
msgstr "Nya nycklar kommer att vara linjära"


msgid "New keys will be constant"
msgstr "Nya nycklar kommer att vara konstanta"


msgid "The custom range in which to create new keys. Only used when not using the scene range"
msgstr "Det anpassade intervallet inom vilket nya nycklar ska skapas. Används endast när scenintervallet inte används."


msgid "Remove Outside Range"
msgstr "Ta bort utanför intervallet"


msgid "Removes keys outside the given range, leaving only the newly baked"
msgstr "Tar bort nycklar utanför det angivna intervallet och lämnar endast de nyligen bakade kvar."


msgid "At which interval to add keys"
msgstr "Vid vilket intervall ska nycklar läggas till"


msgid "Use Scene Range"
msgstr "Använd scenintervall"


msgid "If enabled, the scene start and end frame will be used to determine the bake range"
msgstr "Om denna funktion är aktiverad kommer scenens start- och slutbild att användas för att bestämma bakningsområdet."


msgctxt "Operator"
msgid "Remove Empty Animation Data"
msgstr "Ta bort tomma animationsdata"


msgid "Delete all empty animation data containers from visible data-blocks"
msgstr "Ta bort alla tomma animationsdatakontroller från synliga datablock"


msgctxt "Operator"
msgid "Mouse Click on Channels"
msgstr "Musklick på kanaler"


msgid "Handle mouse clicks over animation channels"
msgstr "Hantera musklick över animationskanaler"


msgid "Select Children Only"
msgstr "Välj endast barn"


msgid "Extend Range"
msgstr "Utöka räckvidden"


msgid "Selection of active channel to clicked channel"
msgstr "Val av aktiv kanal till klickad kanal"


msgctxt "Operator"
msgid "Collapse Channels"
msgstr "Kollapsade kanaler"


