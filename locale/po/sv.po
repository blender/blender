msgstr "Fäst valda nyckelrutor till närmaste markör"


msgctxt "Operator"
msgid "Stash Action"
msgstr "Stash-åtgärd"


msgid "Store this action in the NLA stack as a non-contributing strip for later use"
msgstr "Lagra denna åtgärd i NLA-stacken som en icke-bidragande remsa för senare användning."


msgid "Create New Action"
msgstr "Skapa ny åtgärd"


