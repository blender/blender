msgstr "Normalisera kärna"


msgid "Normalizes the kernel such that it integrates to one"
msgstr "Normaliserar kärnan så att den integreras till ett"


msgid "Upper Left"
msgstr "Övre vänstra hörnet"


msgid "Upper Right"
msgstr "Övre högra hörnet"


msgid "Lower Left"
msgstr "Nedre vänstra hörnet"


msgid "Lower Right"
msgstr "Nedre högra hörnet"


msgid "Extension X"
msgstr "Förlängning X"


msgid "Extension Y"
msgstr "Förlängning Y"


msgid "The extension mode applied to the X axis"
msgstr "Förlängningsläget som tillämpas på X-axeln"


msgid "The extension mode applied to the Y axis"
msgstr "Förlängningsläget som tillämpas på Y-axeln"


msgid "Alpha Crop"
msgstr "Alpha Beskärning"


msgid "The X position of the lower left corner of the crop region"
msgstr "X-positionen för det nedre vänstra hörnet av beskärningsområdet"


msgid "The Y position of the lower left corner of the crop region"
msgstr "Y-positionen för det nedre vänstra hörnet av beskärningsområdet"


msgid "The width of the crop region"
msgstr "Bredden på beskärningsområdet"


msgid "The height of the crop region"
msgstr "Höjden på skördeområdet"


msgid "Sets the areas outside of the crop region to be transparent instead of actually cropping the size of the image"
msgstr "Ställer in områden utanför beskärningsområdet som transparenta istället för att faktiskt beskära bildens storlek."


msgid "The Cryptomatte node in render mode is only supported for scene compositing"
msgstr "Cryptomatte-noden i renderingsläge stöds endast för scenkomponering."


msgid "Render passes in the Viewport compositor are only supported in EEVEE"
msgstr "Renderpass i Viewport-kompositorn stöds endast i EEVEE."


msgid "Node Unsupported"
msgstr "Nod stöds inte"


msgid "Passes Not Supported"
msgstr "Pass som inte stöds"


