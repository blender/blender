msgstr "Ljusstrålningsfördelning på grov yta"


msgid "Beckmann"
msgstr "Beckmann"


msgid "GGX"
msgstr "GGX"


msgid "Ashikhmin-Shirley"
msgstr "Ashikhmin-Shirley"


msgid "Multiscatter GGX"
msgstr "Multiscatter GGX"


